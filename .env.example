# ============================================================
# AnimeFR Bot v6.1 — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez vos valeurs :
#   cp .env.example .env
#   nano .env
#
# ⚠️ NE JAMAIS COMMIT LE FICHIER .env SUR GIT !
# ============================================================

# [OBLIGATOIRE] Token du bot Telegram (obtenu via @BotFather)
BOT_TOKEN=

# [OPTIONNEL] Clé API OpenAI (pour les fonctionnalités IA : /auto, /aisuggest, /airecap)
# Sans cette clé, le bot fonctionne mais les commandes IA sont désactivées.
OPENAI_API_KEY=
