# ============================================================
# AnimeFR Bot — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez vos valeurs
# cp .env.example .env

# Token du bot Telegram (obtenu via @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Clé API OpenAI (pour les fonctionnalités IA - v6+)
OPENAI_API_KEY=your_openai_api_key_here
